# Admin portal credentials
# Defaults are admin / Golois if these values are omitted.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Golois
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# SQLite path for admin persistence (defaults to ./data/admin.sqlite)
SQLITE_DB_PATH=./data/admin.sqlite

# Vonage SMS settings
# Required to send SMS from the /admin portal.
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM=
